# Joplin Data API token — found at Tools → Options → Web Clipper in Joplin Desktop
JOPLIN_API_TOKEN=your-token-here

# Joplin API base URL — default is fine unless you changed the port
JOPLIN_BASE_URL=http://localhost:41184

# --- Semantic search (optional; requires the `[semantic]` extra) ---------------
# Embedding backend: "fastembed" (default, light) or "sentence-transformers".
# SBJ_EMBEDDING_BACKEND=fastembed
# Model id override; empty uses the backend default (bge-small-en-v1.5 / bge-m3).
# SBJ_EMBEDDING_MODEL=
# Vector store: "sqlite-vec" (default, single file) or "chroma".
# SBJ_VECTOR_STORE=sqlite-vec
# Where the index is persisted; default is under your XDG data dir.
# SBJ_INDEX_DIR=
# Auto-sync the index before each semantic search (true/false).
# SBJ_SEMANTIC_AUTO_SYNC=true
